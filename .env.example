# ── Banco de dados ──────────────────────────────────────────────
# Neon (grátis): https://neon.tech — conectar via Vercel Storage
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require

# Desenvolvimento local (alternativa a DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sigma
# DB_USER=sigma
# DB_PASSWORD=sigma123
# DB_SSL=false

# ── Autenticação ───────────────────────────────────────────────
JWT_SECRET=gere_um_segredo_longo_e_aleatorio_aqui

# ── Vercel Blob (obrigatório em produção / plano gratuito) ─────
BLOB_READ_WRITE_TOKEN=
# true = upload direto ao Blob (padrão produção)
# false = disco local em dados/dashboards/ (desenvolvimento)
NEXT_PUBLIC_BLOB_UPLOAD=false

# ── Rate limit Upstash (grátis via Vercel Storage) ─────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NEXT_PUBLIC_VERCEL=1  (definida automaticamente na Vercel)
